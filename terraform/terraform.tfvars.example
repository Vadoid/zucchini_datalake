# Copy to terraform.tfvars and fill in.

project_id = "zucchini-datalake-poc"
region     = "us-central1"
zone       = "us-central1-a"

# Create the project from scratch (needs billing + org or folder):
create_project  = true
billing_account = "XXXXXX-XXXXXX-XXXXXX"
org_id          = "123456789012"
# folder_id     = "123456789012"   # use instead of org_id

# Reuse an existing project instead:
# create_project = false

alloydb_password = "change-me-strong-password"
